# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# caches and temp directories
.temp/
.tmp/
.cache/
.eslintcache

# Runtime data
